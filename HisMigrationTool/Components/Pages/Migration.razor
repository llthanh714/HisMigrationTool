@page "/"
@rendermode InteractiveServer
@using HisMigrationTool.Models
@using HisMigrationTool.Services
@inject MigrationWebService MigrationService

<div class="gh-container">
    <div class="gh-wrapper">
        <h2 class="gh-title">
            <svg aria-hidden="true" height="24" viewBox="0 0 16 16" version="1.1" width="24" class="gh-icon">
                <path fill="currentColor" d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 110-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5v-9zm10.5-1h-8a1 1 0 00-1 1v6.708A2.492 2.492 0 014.5 9h8V1.5z"></path>
            </svg>
            Đồng bộ lượt tiếp nhận (Theo VisitID)
        </h2>

        <!-- Box Tìm Kiếm -->
        <div class="gh-card mb-4">
            <div class="gh-card-body d-flex">
                <input type="text" class="gh-input flex-grow" placeholder="Nhập Visit ID ở hệ thống cũ (VD: IP26000257)..." 
                       @bind="searchVisitId" @bind:event="oninput" @onkeyup="HandleKeyUp" disabled="@(isLoading || isMigrating)" />
                <button class="gh-btn gh-btn-secondary ml-2" @onclick="SearchVisit" disabled="@(isLoading || isMigrating)">
                    @(isLoading ? "Đang xử lý..." : "Tìm kiếm")
                </button>
            </div>
        </div>

        <!-- Alert Thông báo -->
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="gh-alert @(isSuccess ? "gh-alert-success" : "gh-alert-danger")">
                @statusMessage
            </div>
        }

        <!-- Khung Terminal Hiển Thị Log Chi Tiết -->
        @if (executionLogs.Any())
        {
            <div class="gh-card mb-4" style="background-color: #0d1117;">
                <div class="gh-card-header" style="padding: 8px 16px; font-size: 12px; font-family: monospace; color: var(--gh-text-muted); border-bottom: 1px solid var(--gh-border);">
                    Terminal Output Logs
                </div>
                <div class="gh-card-body" style="padding: 12px 16px; max-height: 250px; overflow-y: auto; font-family: 'Courier New', Courier, monospace; font-size: 13px;">
                    @foreach (var log in executionLogs)
                    {
                        <div style="margin-bottom: 4px; color: @(log.Contains("LỖI") || log.Contains("✖") || log.Contains("NGHIÊM TRỌNG") ? "var(--gh-danger-text)" : (log.Contains("✔") ? "var(--gh-success-text)" : "var(--gh-text)"));">
                            @log
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Card Hiển thị Thông tin -->
        @if (currentData != null)
        {
            <div class="gh-card mb-4">
                <div class="gh-card-header">
                    Kết quả truy vấn Visit ID: <span class="gh-text-accent">@searchVisitId</span>
                </div>
                <div class="gh-card-body">
                    @* <h5 style="margin-top:0; margin-bottom: 10px; font-size: 13px; color: var(--gh-text-muted);">THÔNG TIN TIẾP NHẬN</h5> *@
                    <div class="gh-grid">
                        <div class="gh-grid-item"><strong>Mã BN</strong> @currentData.TiepNhan.id_Benhnhan</div>
                        <div class="gh-grid-item"><strong>Họ Tên</strong> @currentData.TiepNhan.Hoten</div>
                        <div class="gh-grid-item"><strong>Năm sinh/Tuổi</strong> @currentData.TiepNhan.Namsinh (@currentData.TiepNhan.Tuoi tuổi)</div>
                        <div class="gh-grid-item"><strong>Giới tính</strong> @currentData.TiepNhan.Gioitinh</div>
                        <div class="gh-grid-item"><strong>Bác sĩ khám</strong> @(string.IsNullOrEmpty(currentData.PhieuChiDinh.Hoten_Bacsi_Lambenhan) ? "N/A" : currentData.PhieuChiDinh.Hoten_Bacsi_Lambenhan)</div>
                        <div class="gh-grid-item"><strong>Khoa TN</strong> @currentData.TiepNhan.id_KhoaPhongTN</div>
                        <div class="gh-grid-item"><strong>Thời gian tiếp nhận</strong> @currentData.TiepNhan.Ngaygiotiepnhan?.ToString("dd/MM/yyyy HH:mm")</div>
                        <div class="gh-grid-item"><strong>Đối tượng</strong> @currentData.TiepNhan.id_DMDoituong</div>
                    </div>

                    @* <hr style="border-color: var(--gh-border); margin: 16px 0;" />
                    
                    <h5 style="margin-top:0; margin-bottom: 10px; font-size: 13px; color: var(--gh-text-muted);">THÔNG TIN BỆNH NHÂN TẠI KHOA (ĐIỀU TRỊ)</h5>
                    <div class="gh-grid">
                        <div class="gh-grid-item"><strong>Khoa điều trị</strong> @currentData.BenhNhanTaiKhoa.Tenkhoa</div>
                        <div class="gh-grid-item"><strong>Trạng thái</strong> <span class="gh-text-accent">@currentData.BenhNhanTaiKhoa.Trangthai</span></div>
                        <div class="gh-grid-item"><strong>Nhân viên nhận bệnh</strong> @currentData.BenhNhanTaiKhoa.Hoten_Nhanvienget</div>
                        <div class="gh-grid-item"><strong>Thời gian vào khoa</strong> @currentData.BenhNhanTaiKhoa.Ngaygio?.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>

                    @if (!string.IsNullOrEmpty(currentData.BenhAnNgoaiTru?.id_Benhnhan))
                    {
                        <hr style="border-color: var(--gh-border); margin: 16px 0;" />
                        <h5 style="margin-top:0; margin-bottom: 10px; font-size: 13px; color: var(--gh-text-muted);">THÔNG TIN BỆNH ÁN NGOẠI TRÚ</h5>
                        <div class="gh-grid">
                            <div class="gh-grid-item"><strong>Phòng khám</strong> @currentData.BenhAnNgoaiTru.Ten_Khoaphong</div>
                            <div class="gh-grid-item"><strong>Bác sĩ khám</strong> @currentData.BenhAnNgoaiTru.Hoten_Bacsi</div>
                            <div class="gh-grid-item"><strong>Thời gian khám</strong> @currentData.BenhAnNgoaiTru.Ngaygio?.ToString("dd/MM/yyyy HH:mm")</div>
                            <div class="gh-grid-item"><strong>Người lập</strong> @currentData.BenhAnNgoaiTru.ten_nguoilap</div>
                        </div>
                    } *@
                </div>
                <div class="gh-card-footer">
                    <button class="gh-btn gh-btn-primary" @onclick="ConfirmMigration" disabled="@isMigrating">
                        @(isMigrating ? "Hệ thống đang đồng bộ..." : "Tiến hành đồng bộ")
                    </button>
                    <button class="gh-btn gh-btn-danger ml-2" @onclick="ClearForm" disabled="@isMigrating">Hủy</button>
                </div>
            </div>
        }
    </div>
</div>

<style>
    :root {
        --gh-bg: #0d1117;
        --gh-card-bg: #161b22;
        --gh-border: #30363d;
        --gh-text: #c9d1d9;
        --gh-text-muted: #8b949e;
        --gh-text-accent: #58a6ff;
        --gh-btn-primary-bg: #238636;
        --gh-btn-primary-hover: #2ea043;
        --gh-btn-secondary-bg: #21262d;
        --gh-btn-secondary-hover: #30363d;
        --gh-btn-danger-bg: #da3633;
        --gh-btn-danger-hover: #b62324;
        --gh-danger-text: #ff7b72;
        --gh-success-text: #3fb950;
    }
    body { background-color: var(--gh-bg); margin: 0; }
    .gh-container { background-color: var(--gh-bg); color: var(--gh-text); min-height: 100vh; padding: 40px 20px; font-family: -apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,Arial,sans-serif; }
    .gh-wrapper { max-width: 800px; margin: 0 auto; }
    .gh-title { display: flex; align-items: center; font-size: 24px; font-weight: 600; margin-bottom: 24px; border-bottom: 1px solid var(--gh-border); padding-bottom: 16px; margin-top: 0;}
    .gh-icon { margin-right: 12px; color: var(--gh-text-muted); }
    .gh-card { background-color: var(--gh-card-bg); border: 1px solid var(--gh-border); border-radius: 6px; overflow: hidden; }
    .gh-card-header { padding: 16px; border-bottom: 1px solid var(--gh-border); background-color: var(--gh-card-bg); font-weight: 600; font-size: 14px;}
    .gh-card-body { padding: 16px; }
    .gh-card-footer { padding: 16px; border-top: 1px solid var(--gh-border); background-color: var(--gh-card-bg); }
    .gh-input { background-color: var(--gh-bg); border: 1px solid var(--gh-border); color: var(--gh-text); border-radius: 6px; padding: 5px 12px; font-size: 14px; line-height: 20px; width: 100%; box-sizing: border-box;}
    .gh-input:focus { border-color: var(--gh-text-accent); outline: none; box-shadow: 0 0 0 3px rgba(88,166,255,0.3); }
    .gh-input:disabled { opacity: 0.6; cursor: not-allowed; }
    .gh-btn { font-weight: 500; font-size: 14px; border-radius: 6px; padding: 5px 16px; cursor: pointer; border: 1px solid rgba(240,246,252,0.1); transition: 0.2s; line-height: 20px;}
    .gh-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .gh-btn-primary { background-color: var(--gh-btn-primary-bg); color: #fff; }
    .gh-btn-primary:hover:not(:disabled) { background-color: var(--gh-btn-primary-hover); }
    .gh-btn-secondary { background-color: var(--gh-btn-secondary-bg); color: var(--gh-text); border-color: rgba(240,246,252,0.1); }
    .gh-btn-secondary:hover:not(:disabled) { background-color: var(--gh-btn-secondary-hover); border-color: var(--gh-text-muted); }
    .gh-btn-danger { background-color: var(--gh-btn-danger-bg); color: #fff; }
    .gh-btn-danger:hover:not(:disabled) { background-color: var(--gh-btn-danger-hover); }
    .gh-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; font-size: 14px;}
    .gh-grid-item { padding: 8px 12px; background: rgba(240,246,252,0.02); border-radius: 6px; border: 1px solid rgba(240,246,252,0.05); }
    .gh-grid-item strong { color: var(--gh-text-muted); font-weight: 600; display: block; margin-bottom: 4px; font-size: 12px; text-transform: uppercase;}
    .gh-alert { padding: 12px 16px; border-radius: 6px; margin-bottom: 16px; border: 1px solid; font-size: 14px; font-weight: 500;}
    .gh-alert-danger { background-color: rgba(255,123,114,0.1); border-color: rgba(255,123,114,0.4); color: var(--gh-danger-text); }
    .gh-alert-success { background-color: rgba(46,160,67,0.1); border-color: rgba(46,160,67,0.4); color: var(--gh-success-text); }
    .d-flex { display: flex; }
    .flex-grow { flex-grow: 1; }
    .ml-2 { margin-left: 8px; }
    .mb-4 { margin-bottom: 16px; }
    .gh-text-accent { color: var(--gh-text-accent); }
</style>

@code {
    private string searchVisitId = "";
    private VisitMigrationData? currentData;
    
    private bool isLoading = false;
    private bool isMigrating = false;
    private bool isSuccess = false;
    private string statusMessage = "";

    // Danh sách chứa các log thời gian thực
    private List<string> executionLogs = new();

    // Hàm nhận log từ Service và ép giao diện cập nhật ngay lập tức
    private void AppendLog(string message)
    {
        executionLogs.Add($"[{DateTime.Now:HH:mm:ss.fff}] {message}");
        InvokeAsync(StateHasChanged);
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchVisit();
    }

    private async Task SearchVisit()
    {
        if (string.IsNullOrWhiteSpace(searchVisitId)) return;

        isLoading = true;
        statusMessage = "";
        currentData = null;
        executionLogs.Clear();
        StateHasChanged();

        try
        {
            // Truyền hàm AppendLog xuống tầng Service để lấy log real-time
            currentData = await MigrationService.SearchVisitAsync(searchVisitId.Trim(), AppendLog);
            isSuccess = true;
            statusMessage = "Truy vấn thành công! Vui lòng xác nhận thông tin bên dưới.";
        }
        catch (Exception ex)
        {
            isSuccess = false;
            statusMessage = $"Tra cứu thất bại: Xem log chi tiết bên dưới";
            AppendLog($"✖ {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmMigration()
    {
        if (currentData == null) return;

        isMigrating = true;
        statusMessage = "";
        executionLogs.Clear(); // Xóa log tìm kiếm cũ để hiện log insert
        StateHasChanged();

        var result = await MigrationService.MigrateVisitAsync(currentData, AppendLog);
        
        isSuccess = result.IsSuccess;
        statusMessage = result.Message;
        
        if (isSuccess)
        {
            currentData = null;
        }

        isMigrating = false;
        StateHasChanged();
    }

    private void ClearForm()
    {
        currentData = null;
        statusMessage = "";
        searchVisitId = "";
        executionLogs.Clear();
    }
}