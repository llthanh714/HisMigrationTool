@page "/"
@rendermode InteractiveServer
@using HisMigrationTool.Models
@using HisMigrationTool.Services
@inject MigrationWebService MigrationService

<div class="gh-container">
    <div class="gh-wrapper">
        <h2 class="gh-title">
            <svg aria-hidden="true" height="24" viewBox="0 0 16 16" version="1.1" width="24" class="gh-icon">
                <path fill="currentColor" d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 110-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5v-9zm10.5-1h-8a1 1 0 00-1 1v6.708A2.492 2.492 0 014.5 9h8V1.5z"></path>
            </svg>
            Đồng bộ hồ sơ bệnh án (Migration)
        </h2>

        <!-- Box Tìm Kiếm -->
        <div class="gh-card mb-4">
            <div class="gh-card-body d-flex">
                <input type="text" class="gh-input flex-grow" placeholder="Nhập mã bệnh nhân ở hệ thống cũ (VD: BN123456)..." 
                       @bind="searchCode" @bind:event="oninput" @onkeyup="HandleKeyUp" />
                <button class="gh-btn gh-btn-secondary ml-2" @onclick="SearchPatient" disabled="@isLoading">
                    @(isLoading ? "Đang truy vấn..." : "Tìm kiếm")
                </button>
            </div>
        </div>

        <!-- Alert Thông báo -->
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="gh-alert @(isSuccess ? "gh-alert-success" : "gh-alert-danger")">
                @statusMessage
            </div>
        }

        <!-- Card Hiển thị Thông tin -->
        @if (currentPatient != null)
        {
            <div class="gh-card mb-4">
                <div class="gh-card-header">
                    Thông tin Lượt Khám Gần Nhất: <span class="gh-text-accent">@currentPatient.MRN</span>
                </div>
                <div class="gh-card-body">
                    <div class="gh-grid">
                        <div class="gh-grid-item"><strong>Họ Tên</strong> @currentPatient.FullName</div>
                        <div class="gh-grid-item"><strong>Ngày sinh</strong> @currentPatient.DateOfBirth?.ToString("dd/MM/yyyy")</div>
                        <div class="gh-grid-item"><strong>Giới tính</strong> @(currentPatient.Gender)</div>
                        <div class="gh-grid-item"><strong>Điện thoại</strong> @(string.IsNullOrEmpty(currentPatient.MobilePhone) ? "N/A" : currentPatient.MobilePhone)</div>
                        <div class="gh-grid-item"><strong>Mã BHYT</strong> @(string.IsNullOrEmpty(currentPatient.PassportNo) ? "N/A" : currentPatient.PassportNo)</div>
                        <div class="gh-grid-item"><strong>Thời gian vào viện</strong> @currentPatient.RegisteredDate?.ToString("dd/MM/yyyy HH:mm")</div>
                        <div class="gh-grid-item"><strong>Khoa/Phòng</strong> @currentPatient.Address</div>
                        <div class="gh-grid-item"><strong>Chẩn đoán</strong> [@currentPatient.Country] @currentPatient.Country</div>
                    </div>
                </div>
                <div class="gh-card-footer">
                    <button class="gh-btn gh-btn-primary" @onclick="ConfirmMigration" disabled="@isMigrating">
                        @(isMigrating ? "Đang đồng bộ..." : "Đồng bộ qua HIS Mới")
                    </button>
                    <button class="gh-btn gh-btn-danger ml-2" @onclick="ClearForm" disabled="@isMigrating">Hủy</button>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* CSS GitHub Dark Theme */
    :root {
        --gh-bg: #0d1117;
        --gh-card-bg: #161b22;
        --gh-border: #30363d;
        --gh-text: #c9d1d9;
        --gh-text-muted: #8b949e;
        --gh-text-accent: #58a6ff;
        --gh-btn-primary-bg: #238636;
        --gh-btn-primary-hover: #2ea043;
        --gh-btn-secondary-bg: #21262d;
        --gh-btn-secondary-hover: #30363d;
        --gh-btn-danger-bg: #da3633;
        --gh-btn-danger-hover: #b62324;
        --gh-danger-text: #ff7b72;
        --gh-success-text: #3fb950;
    }

    /* Ghi đè nền của trang Blazor nếu cần */
    body { background-color: var(--gh-bg); margin: 0; }

    .gh-container { background-color: var(--gh-bg); color: var(--gh-text); min-height: 100vh; padding: 40px 20px; font-family: -apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,Arial,sans-serif; }
    .gh-wrapper { max-width: 800px; margin: 0 auto; }
    .gh-title { display: flex; align-items: center; font-size: 24px; font-weight: 600; margin-bottom: 24px; border-bottom: 1px solid var(--gh-border); padding-bottom: 16px; margin-top: 0;}
    .gh-icon { margin-right: 12px; color: var(--gh-text-muted); }
    
    .gh-card { background-color: var(--gh-card-bg); border: 1px solid var(--gh-border); border-radius: 6px; overflow: hidden; }
    .gh-card-header { padding: 16px; border-bottom: 1px solid var(--gh-border); background-color: var(--gh-card-bg); font-weight: 600; font-size: 14px;}
    .gh-card-body { padding: 16px; }
    .gh-card-footer { padding: 16px; border-top: 1px solid var(--gh-border); background-color: var(--gh-card-bg); }
    
    .gh-input { background-color: var(--gh-bg); border: 1px solid var(--gh-border); color: var(--gh-text); border-radius: 6px; padding: 5px 12px; font-size: 14px; line-height: 20px; width: 100%; box-sizing: border-box;}
    .gh-input:focus { border-color: var(--gh-text-accent); outline: none; box-shadow: 0 0 0 3px rgba(88,166,255,0.3); }
    
    .gh-btn { font-weight: 500; font-size: 14px; border-radius: 6px; padding: 5px 16px; cursor: pointer; border: 1px solid rgba(240,246,252,0.1); transition: 0.2s; line-height: 20px;}
    .gh-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .gh-btn-primary { background-color: var(--gh-btn-primary-bg); color: #fff; }
    .gh-btn-primary:hover:not(:disabled) { background-color: var(--gh-btn-primary-hover); }
    .gh-btn-secondary { background-color: var(--gh-btn-secondary-bg); color: var(--gh-text); border-color: rgba(240,246,252,0.1); }
    .gh-btn-secondary:hover:not(:disabled) { background-color: var(--gh-btn-secondary-hover); border-color: var(--gh-text-muted); }
    .gh-btn-danger { background-color: var(--gh-btn-danger-bg); color: #fff; }
    .gh-btn-danger:hover:not(:disabled) { background-color: var(--gh-btn-danger-hover); }

    .gh-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; font-size: 14px;}
    .gh-grid-item { padding: 8px 12px; background: rgba(240,246,252,0.02); border-radius: 6px; border: 1px solid rgba(240,246,252,0.05); }
    .gh-grid-item strong { color: var(--gh-text-muted); font-weight: 600; display: block; margin-bottom: 4px; font-size: 12px; text-transform: uppercase;}

    .gh-alert { padding: 12px 16px; border-radius: 6px; margin-bottom: 16px; border: 1px solid; font-size: 14px; font-weight: 500;}
    .gh-alert-danger { background-color: rgba(255,123,114,0.1); border-color: rgba(255,123,114,0.4); color: var(--gh-danger-text); }
    .gh-alert-success { background-color: rgba(46,160,67,0.1); border-color: rgba(46,160,67,0.4); color: var(--gh-success-text); }
    
    .d-flex { display: flex; }
    .flex-grow { flex-grow: 1; }
    .ml-2 { margin-left: 8px; }
    .mb-4 { margin-bottom: 16px; }
    .gh-text-accent { color: var(--gh-text-accent); }
</style>

@code {
    private string searchCode = "";
    private PatientMigrationDto currentPatient;
    
    private bool isLoading = false;
    private bool isMigrating = false;
    private bool isSuccess = false;
    private string statusMessage = "";

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchPatient();
    }

    private async Task SearchPatient()
    {
        if (string.IsNullOrWhiteSpace(searchCode)) return;

        isLoading = true;
        statusMessage = "";
        currentPatient = null;
        StateHasChanged();

        try
        {
            currentPatient = await MigrationService.SearchPatientAsync(searchCode.Trim());
            
            if (currentPatient == null)
            {
                isSuccess = false;
                statusMessage = $"Không tìm thấy lượt khám cho bệnh nhân có mã: {searchCode}";
            }
        }
        catch (Exception ex)
        {
            isSuccess = false;
            statusMessage = $"Lỗi kết nối DB ArcusAir: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmMigration()
    {
        if (currentPatient == null) return;

        isMigrating = true;
        statusMessage = "";
        StateHasChanged();

        var result = await MigrationService.MigratePatientAsync(currentPatient);
        
        isSuccess = result.IsSuccess;
        statusMessage = result.Message;
        
        if (isSuccess)
        {
            currentPatient = null;
            searchCode = "";
        }

        isMigrating = false;
        StateHasChanged();
    }

    private void ClearForm()
    {
        currentPatient = null;
        statusMessage = "";
        searchCode = "";
    }
}